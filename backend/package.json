{
  "name": "inytel-presence-api",
  "version": "2.0.0",
  "main": "server.js",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.6.0",
    "pdfkit": "^0.18.0",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test jest --testEnvironment node --testPathIgnorePatterns=rate",
    "test:rate": "jest --testEnvironment node --testPathPatterns=rate"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFiles": [
      "dotenv/config"
    ],
    "testEnvironmentOptions": {
      "env": {
        "DOTENV_CONFIG_PATH": ".env.test"
      }
    }
  }
}
